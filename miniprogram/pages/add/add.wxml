<view class="container">
  <view class="form">
    <view class="form-item">
      <text class="label">取件码 *</text>
      <input class="input" placeholder="请输入取件码" value="{{form.trackingCode}}" bindinput="onInput" data-field="trackingCode" />
    </view>

    <view class="form-item">
      <text class="label">收件人手机号 *</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{form.recipientPhone}}" bindinput="onInput" data-field="recipientPhone" />
    </view>

    <view class="form-item">
      <text class="label">货架位置 *</text>
      <input class="input" placeholder="例如：A-01" value="{{form.shelfNo}}" bindinput="onInput" data-field="shelfNo" />
    </view>

    <button class="btn-submit" bindtap="submit">{{isEdit ? '保存修改' : '添加快递'}}</button>
  </view>
</view>