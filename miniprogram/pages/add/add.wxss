.container {
    min-height: 100vh;
    background-color: #f5f5f5;
    padding: 30rpx;
  }
  
  .form {
    background: white;
    border-radius: 16rpx;
    padding: 40rpx 30rpx;
  }
  
  .form-item {
    margin-bottom: 40rpx;
  }
  
  .label {
    display: block;
    font-size: 30rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 16rpx;
  }
  
  .input {
    width: 100%;
    height: 80rpx;
    padding: 0 20rpx;
    border: 2rpx solid #e5e5e5;
    border-radius: 12rpx;
    font-size: 28rpx;
    box-sizing: border-box;
    line-height: 80rpx;
    transition: all 0.3s;
  }
  
  .input:focus {
    border-color: #07c160;
  }
  
  .valid-input {
    border-color: #07c160;
    background-color: #f6ffed;
  }
  
  .invalid-input {
    border-color: #ff4d4f;
    background-color: #fff2f0;
  }
  
  .hint {
    display: block;
    margin-top: 16rpx;
    font-size: 24rpx;
  }
  
  .hint-success {
    color: #07c160;
  }
  
  .hint-error {
    color: #ff4d4f;
  }
  
  .format-tip {
    display: block;
    margin-top: 16rpx;
    font-size: 24rpx;
    color: #999;
  }
  
  .btn-submit {
    margin-top: 40rpx;
    background-color: #07c160;
    color: white;
    font-size: 32rpx;
    border-radius: 12rpx;
    padding: 24rpx;
    transition: all 0.3s;
  }
  
  .btn-submit[disabled] {
    background-color: #ccc;
    color: #999;
    opacity: 0.6;
  }