/* pages/add/add.wxss */
.container {
    min-height: 100vh;
    background-color: #f5f5f5;
    padding: 30rpx;
  }
  
  .form {
    background: white;
    border-radius: 16rpx;
    padding: 40rpx 30rpx;
  }
  
  .form-item {
    margin-bottom: 40rpx;
  }
  
  .label {
    display: block;
    font-size: 30rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 16rpx;
  }
  
  .input {
    width: 100%;
    height: 80rpx;
    padding: 0 20rpx;
    border: 1rpx solid #e5e5e5;
    border-radius: 12rpx;
    font-size: 28rpx;
    box-sizing: border-box;
    line-height: 80rpx;
  }
  
  .btn-submit {
    margin-top: 40rpx;
    background-color: #07c160;
    color: white;
    font-size: 32rpx;
    border-radius: 12rpx;
    padding: 24rpx;
  }