.container {
    min-height: 100vh;
    background-color: #f5f5f5;
    padding: 20rpx;
  }
  
  .page-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60rpx 0 40rpx;
    background: white;
    border-radius: 0 0 30rpx 30rpx;
    margin-bottom: 20rpx;
  }
  
  .header-icon {
    width: 100rpx;
    height: 100rpx;
    margin-bottom: 20rpx;
  }
  
  .header-title {
    font-size: 40rpx;
    font-weight: bold;
    color: #07c160;
    margin-bottom: 10rpx;
  }
  
  .header-subtitle {
    font-size: 24rpx;
    color: #999;
  }
  
  .search-area {
    display: flex;
    background: white;
    padding: 20rpx;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
    align-items: center;
    gap: 10rpx;
  }
  
  .phone-input {
    flex: 1;
    height: 70rpx;
    background: #f5f5f5;
    border-radius: 12rpx;
    padding: 0 60rpx 0 20rpx;
    font-size: 28rpx;
  }
  
  .clear-btn {
    position: absolute;
    left: auto;
    right: 180rpx;
    width: 48rpx;
    height: 48rpx;
    background: #ccc;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 28rpx;
  }
  
  .clear-btn:active {
    background: #999;
  }

  .search-btn {
    flex-shrink: 0;
    background-color: #07c160;
    color: white;
    font-size: 28rpx;
    border-radius: 12rpx;
    height: 70rpx;
    padding: 0 30rpx;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .search-btn:active {
    opacity: 0.8;
  }
  
  .header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 30rpx 20rpx;
    background-color: white;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
  }
  
  .title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
  }
  
  .count {
    font-size: 28rpx;
    color: #999;
  }
  
  .parcel-card {
    background: white;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  }
  
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 20rpx;
    border-bottom: 1rpx solid #eee;
    margin-bottom: 20rpx;
  }
  
  .tracking-code {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
  }
  
  .status {
    font-size: 26rpx;
    padding: 6rpx 16rpx;
    border-radius: 30rpx;
  }
  
  .status-waiting {
    background-color: #fff7e6;
    color: #fa8c16;
  }
  
  .info-row {
    font-size: 28rpx;
    padding: 8rpx 0;
  }
  
  .label {
    color: #999;
  }
  
  .value {
    color: #333;
  }
  
  .btn-take {
    margin-top: 20rpx;
    background-color: #07c160;
    color: white;
    font-size: 28rpx;
    border-radius: 12rpx;
  }
  
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  background: white;
  border-radius: 16rpx;
  margin-top: 100rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #ccc;
}

.tabs {
    display: flex;
    background: white;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
  }
  
  .tab {
    flex: 1;
    text-align: center;
    padding: 20rpx;
    font-size: 28rpx;
    color: #666;
  }
  
  .tab.active {
    color: #07c160;
    border-bottom: 4rpx solid #07c160;
  }
  
  .status-done {
    background-color: #f6ffed;
    color: #52c41a;
  }