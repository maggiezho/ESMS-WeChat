/* pages/index/index.wxss */
.container {
    min-height: 100vh;
    background-color: #f5f5f5;
    padding: 20rpx;
  }
  
  /* 查询区域 */
  .search-area {
    display: flex;
    background: white;
    padding: 20rpx;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
    align-items: center;
    gap: 20rpx;
  }
  
  .phone-input {
    flex: 1;
    height: 70rpx;
    background: #f5f5f5;
    border-radius: 12rpx;
    padding: 0 20rpx;
    font-size: 28rpx;
  }
  
  .search-btn {
    flex-shrink: 0;
    background-color: #07c160;
    color: white;
    font-size: 28rpx;
    border-radius: 12rpx;
    height: 70rpx;
    padding: 0 30rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    width: auto;
    cursor: pointer;
  }
  
  .search-btn:active {
    opacity: 0.8;
  }
  
  .header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 30rpx 20rpx;
    background-color: white;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
  }
  
  .title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
  }
  
  .count {
    font-size: 28rpx;
    color: #999;
  }
  
  .parcel-card {
    background: white;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  }
  
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 20rpx;
    border-bottom: 1rpx solid #eee;
    margin-bottom: 20rpx;
  }
  
  .tracking-code {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
  }
  
  .status {
    font-size: 26rpx;
    padding: 6rpx 16rpx;
    border-radius: 30rpx;
  }
  
  .status-waiting {
    background-color: #fff7e6;
    color: #fa8c16;
  }
  
  .info-row {
    font-size: 28rpx;
    padding: 8rpx 0;
  }
  
  .label {
    color: #999;
  }
  
  .value {
    color: #333;
  }
  
  .btn-take {
    margin-top: 20rpx;
    background-color: #07c160;
    color: white;
    font-size: 28rpx;
    border-radius: 12rpx;
  }
  
  .empty-state {
    text-align: center;
    padding: 100rpx;
    color: #999;
  }

  /* Tab 切换样式 */
.tabs {
    display: flex;
    background: white;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
  }
  
  .tab {
    flex: 1;
    text-align: center;
    padding: 20rpx;
    font-size: 28rpx;
    color: #666;
  }
  
  .tab.active {
    color: #07c160;
    border-bottom: 4rpx solid #07c160;
  }
  
  /* 已取状态样式 */
  .status-done {
    background-color: #f6ffed;
    color: #52c41a;
  }