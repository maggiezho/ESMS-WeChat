  <view class="container">
    <!-- 页面装饰头部 -->
    <view class="page-header">
        <image class="header-icon" src="/images/express.png" mode="aspectFit"></image>
        <text class="header-title">快递驿站</text>
        <text class="header-subtitle">扫码取件，轻松便捷</text>
    </view>
    <!-- 手机号查询区域 -->
    <view class="search-area">
        <input class="phone-input" placeholder="请输入收件人手机号" 
            value="{{phoneNum}}" bindinput="onPhoneInput" type="number" maxlength="11" />
        <!-- 清除按钮：只在有内容时显示 -->
        <view class="clear-btn" wx:if="{{phoneNum}}" catchtap="clearPhoneInput">
            <text>✕</text>
        </view>
        <view class="search-btn" bindtap="searchParcels">查询</view>
  </view>

  <!-- 新增：Tab 切换 -->
  <view class="tabs">
    <view class="tab {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-tab="0">
      待取快递 ({{waitingCount}})
    </view>
    <view class="tab {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-tab="1">
      历史记录 ({{historyCount}})
    </view>
  </view>

  <!-- 待取列表 -->
  <view class="parcel-list" wx:if="{{currentTab === 0}}">
    <block wx:for="{{waitingList}}" wx:key="_id">
      <!-- 卡片内容保持不变，和你原来的 index.wxml 一样 -->
      <view class="parcel-card">
        <view class="card-header">
          <text class="tracking-code">取件码：{{item.trackingCode}}</text>
          <text class="status status-waiting">待取</text>
        </view>
        <view class="card-body">
          <view class="info-row">
            <text class="label">货架位置：</text>
            <text class="value">{{item.shelfNo}}</text>
          </view>
          <view class="info-row">
            <text class="label">入库时间：</text>
            <text class="value">{{item.createTimeFormatted}}</text>
          </view>
        </view>
        <button class="btn-take" data-id="{{item._id}}" data-code="{{item.trackingCode}}" bindtap="scanToTake">
          扫码取件
        </button>
      </view>
    </block>
  </view>

  <!-- 历史列表 -->
  <view class="parcel-list" wx:if="{{currentTab === 1}}">
    <block wx:for="{{historyList}}" wx:key="_id">
      <view class="parcel-card">
        <view class="card-header">
          <text class="tracking-code">取件码：{{item.trackingCode}}</text>
          <text class="status status-done">已取</text>
        </view>
        <view class="card-body">
          <view class="info-row">
            <text class="label">货架位置：</text>
            <text class="value">{{item.shelfNo}}</text>
          </view>
          <view class="info-row">
            <text class="label">取件时间：</text>
            <text class="value">{{item.takeTimeFormatted}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 空状态：未查询时 -->
  <view wx:elif="{{!hasSearched}}" class="empty-state">
    <image class="empty-icon" src="/images/empty-search.png" mode="aspectFit"></image>
    <text class="empty-text">请输入手机号查询快递</text>
    <text class="empty-desc">输入收件人手机号，查看待取件</text>
  </view>

  <!-- 空状态：查询后无结果 -->
  <view wx:if="{{hasSearched && currentTab === 0 && waitingList.length === 0}}" class="empty-state">
    <image class="empty-icon" src="/images/empty-box.png" mode="aspectFit"></image>
    <text class="empty-text">暂无待取快递</text>
    <text class="empty-desc">该手机号没有待取包裹</text>
  </view>

  <view wx:if="{{hasSearched && currentTab === 1 && historyList.length === 0}}" class="empty-state">
    <image class="empty-icon" src="/images/empty-history.png" mode="aspectFit"></image>
    <text class="empty-text">暂无历史记录</text>
    <text class="empty-desc">该手机号还没有取件记录</text>
  </view>
</view>