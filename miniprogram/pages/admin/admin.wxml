<view class="dashboard">
  <view class="card">
    <text class="label">待取件</text>
    <text class="value">{{countWaiting}}</text>
  </view>
  <view class="card">
    <text class="label">今日入库</text>
    <text class="value">{{countToday}}</text>
  </view>
</view>

<view class="container">
  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="btn-add" bindtap="goToAdd">+ 添加快递</button>
  </view>

  <!-- 改造后的搜索框 -->
  <view class="search-box">
    <view class="search-selector">
      <picker mode="selector" range="{{searchTypes}}" bindchange="onSearchTypeChange" value="{{searchTypeIndex}}">
        <view class="selector-text">
          {{searchTypes[searchTypeIndex]}}
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>
    <input placeholder="请输入搜索内容" bindinput="onSearchInput" class="search-input" />
  </view>

  <!-- 筛选Tab -->
  <view class="tabs">
    <view class="tab {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-tab="0">待取件</view>
    <view class="tab {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-tab="1">全部快递</view>
  </view>

  <!-- 快递列表 -->
  <view class="parcel-list">
    <block wx:for="{{list}}" wx:key="_id">
      <view class="parcel-card">
        <view class="card-header">
          <text class="tracking-code">取件码：{{item.trackingCode}}</text>
          <text class="status {{item.status === 0 ? 'status-waiting' : 'status-done'}}">
            {{item.status === 0 ? '待取' : '已取'}}
          </text>
        </view>
        <view class="card-body">
          <view class="info-row">
            <text class="label">手机号：</text>
            <text class="value">{{item.recipientPhone}}</text>
          </view>
          <view class="info-row">
            <text class="label">货架位置：</text>
            <text class="value">{{item.shelfNo}}</text>
          </view>
          <view class="info-row">
            <text class="label">入库时间：</text>
            <text class="value">{{item.createTimeFormatted}}</text>
          </view>
        </view>
        <view class="card-actions">
          <button class="btn-edit" data-id="{{item._id}}" bindtap="editParcel">编辑</button>
          <button class="btn-delete" data-id="{{item._id}}" bindtap="deleteParcel">删除</button>
          <button class="btn-notify" data-phone="{{item.recipientPhone}}" bindtap="sendSMS">提醒</button>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{list.length === 0}}" class="empty-state">
    <text>暂无数据</text>
  </view>
</view>