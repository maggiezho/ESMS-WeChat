/* pages/admin/admin.wxss */
  .container {
    min-height: 100vh;
    background-color: #f5f5f5;
    padding: 20rpx;
  }
  
  .action-bar {
    display: flex;
    gap: 20rpx;
    margin-bottom: 20rpx;
  }
  
  .btn-add, .btn-scan-take, .btn-scan-add {
    flex: 1;
    font-size: 28rpx;
    border-radius: 12rpx;
    height: 80rpx;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .btn-scan-add {
    background-color: #ff9f43;
    color: white;
  }
  
  .btn-scan-take {
    background-color: #1890ff;
    color: white;
  }
  
  .btn-add {
    background-color: #07c160;
    color: white;
  }
  
  .tabs {
    display: flex;
    background: white;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
  }
  
  .tab {
    flex: 1;
    text-align: center;
    padding: 20rpx;
    font-size: 28rpx;
    color: #666;
  }
  
  .tab.active {
    color: #07c160;
    border-bottom: 4rpx solid #07c160;
  }
  
  .parcel-card {
    background: white;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
  }
  
  .card-header {
    display: flex;
    justify-content: space-between;
    padding-bottom: 20rpx;
    border-bottom: 1rpx solid #eee;
  }
  
  .tracking-code {
    font-size: 32rpx;
    font-weight: bold;
  }
  
  .status-waiting {
    color: #fa8c16;
  }
  
  .status-done {
    color: #999;
  }
  
  .info-row {
    font-size: 28rpx;
    padding: 8rpx 0;
  }
  
  .label {
    color: #999;
  }
  
  .card-actions {
    display: flex;
    gap: 20rpx;
    margin-top: 20rpx;
  }
  
  .btn-edit, .btn-delete, .btn-notify {
    flex: 1;
    font-size: 28rpx;
    border-radius: 12rpx;
  }
  
  .btn-edit {
    background-color: #1890ff;
    color: white;
  }
  
  .btn-delete {
    background-color: #ff4d4f;
    color: white;
  }
  
  .empty-state {
    text-align: center;
    padding: 100rpx;
    color: #999;
  }
  
  .dashboard {
    display: flex;
    justify-content: space-around;
    margin: 20rpx;
    padding: 30rpx;
    background: #fff;
    border-radius: 16rpx;
  }
  
  /* 重点修改的搜索框样式 */
  .search-box {
    margin: 20rpx;
    background: white;
    padding: 10rpx 10rpx 10rpx 20rpx;
    border-radius: 50rpx;
    display: flex;
    align-items: center;
    gap: 10rpx;
  }
  
  .search-selector {
    width: 120rpx;
    border-right: 1rpx solid #eee;
    padding-right: 10rpx;
  }
  
  .selector-text {
    font-size: 26rpx;
    color: #666;
    text-align: center;
  }
  
  .search-input {
    flex: 1;
    font-size: 28rpx;
    padding: 10rpx 0;
    margin-left: 10rpx;
  }
  
  .btn-notify {
    background-color: #ff9f43;
    color: white;
  }