/* pages/history/history.wxss */
.container {
    min-height: 100vh;
    background-color: #f5f5f5;
    padding: 20rpx;
  }
  
  .header {
    padding: 30rpx 20rpx;
    background-color: white;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
  }
  
  .title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
  }
  
  .parcel-card {
    background: white;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  }
  
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 20rpx;
    border-bottom: 1rpx solid #eee;
    margin-bottom: 20rpx;
  }
  
  .tracking-code {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
  }
  
  .status-done {
    font-size: 26rpx;
    padding: 6rpx 16rpx;
    border-radius: 30rpx;
    background-color: #f6ffed;
    color: #52c41a;
  }
  
  .info-row {
    font-size: 28rpx;
    padding: 8rpx 0;
  }
  
  .label {
    color: #999;
  }
  
  .value {
    color: #333;
  }
  
  .empty-state {
    text-align: center;
    padding: 100rpx;
    color: #999;
  }